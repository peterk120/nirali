{
  "name": "nirali-sai-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --recursive dev",
    "dev:all": "pnpm --recursive dev",
    "dev:boutique": "pnpm --filter=@nirali-sai/boutique dev",
    "build": "pnpm --recursive build",
    "start": "pnpm --recursive start",
    "start:boutique": "pnpm --filter=@nirali-sai/boutique start",
    "lint": "pnpm --recursive lint"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "description": "A monorepo containing four luxury Indian bridal/fashion web applications built with Next.js 14, TypeScript, and Tailwind CSS.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "formidable": "^3.5.4",
    "framer-motion": "^10.18.0",
    "jose": "^6.1.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.292.0",
    "next-themes": "^0.4.6",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^2.6.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  }
}
